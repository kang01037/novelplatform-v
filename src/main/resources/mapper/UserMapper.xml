<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.novelplatformv.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="org.example.novelplatformv.entity.User">
        <id column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="email" property="email"/>
        <result column="phone" property="phone"/>
        <result column="avatar" property="avatar"/>
        <result column="nickname" property="nickname"/>
        <result column="gender" property="gender"/>
        <result column="birthday" property="birthday"/>
        <result column="user_status" property="userStatus"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="login_count" property="loginCount"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        user_id, username, password, email, phone, avatar, nickname, gender, birthday,
        user_status, last_login_time, login_count, created_time, updated_time, deleted
    </sql>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user
        WHERE user_id = #{userId} AND deleted = 0
    </select>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user
        WHERE username = #{username} AND deleted = 0
    </select>

    <select id="selectByUsernameWithoutDeleted" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user
        WHERE username = #{username}
    </select>

    <select id="selectAllUsers" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user
        WHERE deleted = 0
    </select>

    <insert id="insertUser" parameterType="org.example.novelplatformv.entity.User" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO user (
            username, password, email, phone, avatar, nickname, gender, birthday,
            user_status, last_login_time, login_count, created_time, updated_time, deleted
        ) VALUES (
                     #{username}, #{password}, #{email}, #{phone}, #{avatar}, #{nickname}, #{gender}, #{birthday},
                     #{userStatus}, #{lastLoginTime}, #{loginCount}, #{createdTime}, #{updatedTime}, #{deleted}
                 )
    </insert>

    <update id="updateUser" parameterType="org.example.novelplatformv.entity.User">
        UPDATE user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="email != null">email = #{email},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthday != null">birthday = #{birthday},</if>
            <if test="userStatus != null">user_status = #{userStatus},</if>
            <if test="lastLoginTime != null">last_login_time = #{lastLoginTime},</if>
            <if test="loginCount != null">login_count = #{loginCount},</if>
            <if test="updatedTime != null">updated_time = #{updatedTime},</if>
            <if test="deleted != null">deleted = #{deleted},</if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <update id="updateLastLoginTime">
        UPDATE user
        SET last_login_time = NOW()
        WHERE user_id = #{userId}
    </update>

    <update id="incrementLoginCount">
        UPDATE user
        SET login_count = login_count + 1
        WHERE user_id = #{userId}
    </update>


</mapper>
